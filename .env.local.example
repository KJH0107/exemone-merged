# exemONE Clone — 환경 변수 설정 예시
# 실제 사용 시 이 파일을 .env.local 로 복사하고 값을 채우세요.
# cp .env.local.example .env.local

# ── API 기본 URL ──────────────────────────────────
# 개발 환경: 로컬 백엔드 서버 주소
# 프로덕션: 실제 API 서버 주소
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ── 인증 ──────────────────────────────────────────
# TODO: OAuth / JWT 연동 시 사용
# NEXT_PUBLIC_AUTH_URL=http://localhost:8080/auth
# NEXTAUTH_SECRET=your-secret-here

# ── 기타 ──────────────────────────────────────────
# 폴링 간격 (ms), 기본 5000
# NEXT_PUBLIC_POLL_INTERVAL=5000
